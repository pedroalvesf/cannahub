// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  password     String
  name         String?
  isActive     Boolean        @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  RefreshTokens RefreshToken[]
  AccessTokens  AccessToken[]
  LoginHistory LoginHistory[]
  Devices      Device[]

  Roles        UserRole[]
  AuditLogs    AuditLog[]     @relation("UserAuditLogs")
  PerformedAudits AuditLog[]     @relation("PerformedAudits")
  OnboardingSession OnboardingSession?

  @@index([email])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  deviceId  String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  revoked Boolean @default(false)
  createdAt DateTime  @default(now())

  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Device    Device   @relation(fields: [deviceId], references: [id])


  @@index([userId])
  @@index([token])
}

model Role {
  id              String       @id @default(uuid())
  name            String       @unique
  slug            String       @unique
  description     String?
  level           Int          @default(0)
  assignableRoles String[]     @default([])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  Users           UserRole[]
  Permissions     RolePermission[]

  @@index([name])
  @@index([level])
  @@index([slug])
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique
  slug        String           @unique
  description String?
  resource    String           // "users", "posts", "devices"
  action      String           // "create", "read", "update", "delete", "manage"
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  
  Roles       RolePermission[]

  @@unique([resource, action])
  @@index([slug])
  @@index([resource])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedBy String?
  assignedAt DateTime @default(now())
  
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  
  Role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  Permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  resource    String?
  resourceId  String?
  changes     Json?
  performedBy String
  ipAddress   String
  userAgent   String?
  createdAt   DateTime @default(now())
  
  User        User     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  Performer   User     @relation("PerformedAudits", fields: [performedBy], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([performedBy])
}
model AccessToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked Boolean @default(false)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Device {
  id               String        @id @default(uuid())
  userId           String
  name             String
  type             String
  operatingSystem  String
  ipAddress        String
  browser          String
  location         String
  lastLogin        DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime?     @updatedAt
  active           Boolean       @default(true)
  User             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  RefreshToken     RefreshToken[]

  @@index([userId])
}

// --- Onboarding ---

model OnboardingSession {
  id              String   @id @default(uuid())
  userId          String   @unique
  status          String   @default("in_progress") // in_progress | awaiting_prescription | completed | escalated
  currentStep     Int      @default(1)

  // Dados estruturados extraídos (pela IA ou cards)
  condition       String?  // HealthCondition enum
  accountType     String?  // AccountType enum
  experience      String?  // ExperienceLevel enum
  preferredForm   String?  // UsageForm enum
  hasPrescription Boolean?
  needsDoctor     Boolean?
  assistedAccess  Boolean?
  growingInterest Boolean?

  // Respostas brutas do paciente (texto livre)
  rawResponses    Json     @default("[]")

  // Resumo gerado pela IA
  summary         String?

  // Escalação para atendente humano
  escalatedAt     DateTime?
  escalatedReason String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  SupportTickets  SupportTicket[]

  @@index([userId])
  @@index([status])
}

model SupportTicket {
  id          String   @id @default(uuid())
  sessionId   String
  status      String   @default("open") // open | in_progress | resolved | closed
  assignedTo  String?
  context     Json     // Snapshot do que o paciente já respondeu

  createdAt   DateTime @default(now())
  closedAt    DateTime?

  Session     OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  Messages    SupportMessage[]

  @@index([sessionId])
  @@index([status])
}

model SupportMessage {
  id        String   @id @default(uuid())
  ticketId  String
  sender    String   // patient | agent | system
  content   String

  createdAt DateTime @default(now())

  Ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Doctor {
  id              String   @id @default(uuid())
  name            String
  crm             String   @unique
  state           String
  specialties     String[]
  telemedicine    Boolean  @default(false)
  consultationFee String?
  contactInfo     Json
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([state])
  @@index([crm])
}